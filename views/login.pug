doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Login - Transport System
    link(rel='icon' type='image/png' href='/img/favicon.png')
    link(rel='stylesheet' href='/css/styles.css')
    link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css')
    style.
      :root {
          --mint: #0b5af3;
          --mint-dark: #0847c2;
          --paper: #f4f5f6;
          --text: #2f3238;
      }

      * {
          box-sizing: border-box;
      }

      body {
          margin: 0;
          min-height: 100vh;
          font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
          color: var(--text);
          background: radial-gradient(circle at 10% 15%, #dbe8ff 0, #dbe8ff 14%, transparent 14%), var(--paper);
          overflow: hidden;
      }

      .login-container {
          min-height: 100vh;
          display: grid;
          grid-template-columns: 1.2fr 1fr;
      }

      .art-panel {
          position: relative;
          overflow: hidden;
          display: flex;
          align-items: center;
          justify-content: center;
          padding: 2rem;
      }

      .art-wave {
          position: absolute;
          width: 120%;
          height: 95%;
          left: -35%;
          bottom: -55%;
          background: linear-gradient(130deg, #0b5af3 0%, #0a53e6 50%, #0847c2 100%);
          border-radius: 50%;
          animation: waveFloat 7s ease-in-out infinite;
      }

      .blob {
          position: absolute;
          border-radius: 50%;
          background: rgba(11, 90, 243, 0.18);
      }

      .blob.a {
          width: 280px;
          height: 210px;
          left: 16%;
          top: 12%;
          animation: blobMove 6s ease-in-out infinite;
      }

      .blob.b {
          width: 160px;
          height: 120px;
          left: 42%;
          top: 30%;
          animation: blobMove 8s ease-in-out infinite reverse;
      }

      .phone {
          width: 180px;
          height: 355px;
          border-radius: 28px;
          border: 8px solid #304476;
          background: linear-gradient(180deg, #1a56d2 0%, #1142aa 100%);
          position: relative;
          box-shadow: 0 18px 50px rgba(0, 0, 0, 0.2);
          z-index: 2;
          animation: cardUp 1s ease-out forwards;
      }

      .phone::before {
          content: "";
          position: absolute;
          width: 74px;
          height: 16px;
          background: #304476;
          border-radius: 0 0 12px 12px;
          left: 50%;
          top: -1px;
          transform: translateX(-50%);
      }

      .phone-screen {
          position: absolute;
          inset: 24px 14px 14px 14px;
          border-radius: 18px;
          background: linear-gradient(180deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.08));
          border: 1px solid rgba(255, 255, 255, 0.26);
          display: flex;
          align-items: center;
          justify-content: center;
          color: #fff;
      }

      .phone-logo-wrap {
          width: 84px;
          height: 84px;
          border-radius: 18px;
          background: rgba(255, 255, 255, 0.9);
          display: flex;
          align-items: center;
          justify-content: center;
          box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
      }

      .phone-logo {
          width: 58px;
          height: 58px;
          object-fit: contain;
          filter: drop-shadow(0 3px 6px rgba(0, 0, 0, 0.15));
      }

      .form-panel {
          display: flex;
          align-items: center;
          justify-content: center;
          padding: 2rem 2.2rem;
          animation: panelSlide 0.8s ease-out;
      }

      .login-box {
          width: 100%;
          max-width: 420px;
      }

      .avatar {
          width: 116px;
          height: 116px;
          border-radius: 50%;
          background: #e8e8e8;
          margin: 0 auto 1.2rem;
          display: flex;
          align-items: center;
          justify-content: center;
          color: #4b5563;
          font-size: 3.9rem;
          animation: avatarPop 0.9s ease-out;
      }

      .title {
          margin: 0;
          text-align: center;
          font-size: 3rem;
          letter-spacing: 1px;
          font-weight: 800;
      }

      .login-alert {
          margin: 1rem 0 1.1rem;
          padding: 0.75rem 0.85rem;
          border-radius: 10px;
          background: #fee2e2;
          color: #b91c1c;
          border: 1px solid #fecaca;
          font-size: 0.92rem;
          animation: shakeIn 0.35s ease-out;
      }

      .field {
          margin-top: 1rem;
      }

      .field-label {
          display: flex;
          align-items: center;
          gap: 0.5rem;
          font-size: 1.05rem;
          font-weight: 700;
          color: #656a73;
      }

      .field-label i {
          color: var(--mint);
      }

      .login-form input {
          width: 100%;
          border: none;
          border-bottom: 3px solid #d1d5db;
          background: transparent;
          padding: 0.65rem 0.1rem 0.7rem;
          font-size: 1.8rem;
          font-weight: 700;
          color: #49505a;
          transition: border-color 0.2s ease;
      }

      .login-form input::placeholder {
          color: #b0b5bd;
          font-size: 1.55rem;
          font-weight: 600;
      }

      .login-form input:focus {
          outline: none;
          border-bottom-color: var(--mint);
      }

      .forgot {
          text-align: right;
          margin-top: 0.45rem;
          font-size: 1.05rem;
          color: #9097a1;
          text-decoration: none;
          display: inline-block;
          width: 100%;
      }

      .login-btn {
          margin-top: 1.3rem;
          width: 100%;
          border: none !important;
          border-radius: 999px;
          padding: 0.95rem 1rem;
          font-size: 2rem;
          font-weight: 800;
          color: #fff !important;
          background: linear-gradient(90deg, #0847c2, #0b5af3) !important;
          cursor: pointer;
          box-shadow: 0 14px 30px rgba(11, 90, 243, 0.3);
          transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .login-btn:hover {
          transform: translateY(-2px);
          background: linear-gradient(90deg, #073ba1, #0a50da) !important;
          box-shadow: 0 20px 38px rgba(11, 90, 243, 0.34);
      }

      .login-btn:active {
          transform: translateY(0);
          background: linear-gradient(90deg, #06368f, #0946bf) !important;
      }

      @keyframes panelSlide {
          from { transform: translateX(30px); opacity: 0; }
          to { transform: translateX(0); opacity: 1; }
      }

      @keyframes cardUp {
          from { transform: translateY(35px); opacity: 0; }
          to { transform: translateY(0); opacity: 1; }
      }

      @keyframes avatarPop {
          0% { transform: scale(0.8); opacity: 0; }
          75% { transform: scale(1.05); }
          100% { transform: scale(1); opacity: 1; }
      }

      @keyframes shakeIn {
          0% { transform: translateX(-8px); opacity: 0; }
          50% { transform: translateX(4px); }
          100% { transform: translateX(0); opacity: 1; }
      }

      @keyframes waveFloat {
          0%, 100% { transform: translateY(0); }
          50% { transform: translateY(-14px); }
      }

      @keyframes blobMove {
          0%, 100% { transform: translateY(0) translateX(0); }
          50% { transform: translateY(18px) translateX(10px); }
      }

      @media (max-width: 980px) {
          body {
              overflow-y: auto;
          }

          .login-container {
              grid-template-columns: 1fr;
          }

          .art-panel {
              min-height: 280px;
          }

          .art-wave {
              width: 140%;
              height: 100%;
              left: -20%;
              bottom: -65%;
          }

          .phone {
              width: 138px;
              height: 275px;
          }

          .phone-screen {
              font-size: 2.6rem;
              padding-bottom: 1.4rem;
          }

          .title {
              font-size: 2.3rem;
          }

          .login-form input {
              font-size: 1.3rem;
          }

          .login-btn {
              font-size: 1.45rem;
          }
      }
  body
    .login-container
      .art-panel
        .blob.a
        .blob.b
        .art-wave
        .phone
          .phone-screen
            .phone-logo-wrap
              img.phone-logo(src="/img/favicon.png" alt="Logo PAB")
      .form-panel
        .login-box
          .avatar
            i.bi.bi-person-circle
          h1.title WELCOME

          if error
            .login-alert
              i.bi.bi-exclamation-triangle-fill
              |  #{error}

          form.login-form(method="post" action="/login")
            .field
              label.field-label(for="email")
                i.bi.bi-person-fill
                |  Email
              input#email(type="email" name="email" placeholder="Masukkan email Anda" required)
            .field
              label.field-label(for="password")
                i.bi.bi-lock-fill
                |  Password
              input#password(type="password" name="password" placeholder="Masukkan password Anda" required)
              a.forgot(href="#") Forgot Password?
            button.login-btn(type="submit")
              i.bi.bi-box-arrow-in-right
              |  LOGIN
